{
  "name": "@zyno-io/rtc-session-gateway",
  "version": "0.0.0",
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "APP_ENV=development npm-run-all clean -p dev:tsc dev:run",
    "dev:tsc": "tsc -w --preserveWatchOutput -p tsconfig.json",
    "dev:run": "sh -c 'while ! [ -f dist/index.js ]; do sleep 1; done; yarn start:dist:debug'",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs --host 0.0.0.0",
    "docs:preview": "vitepress preview docs --host 0.0.0.0",
    "e2e:compose": "node scripts/run-compose-e2e.mjs",
    "format": "oxfmt",
    "start": "node .",
    "start:dist:debug": "node --watch --inspect=9228 dist/index.js",
    "start:dist:debug:wait": "node --watch --inspect-brk=9228 dist/index.js",
    "test": "tsx --test test/**/*.test.ts"
  },
  "author": "Zyno Consulting <hello@zyno.io>",
  "license": "UNLICENSED",
  "dependencies": {
    "axios": "^1.18.1",
    "drachtio-srf": "^5.0.27",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.59.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "werift": "^0.23.0"
  },
  "resolutions": {
    "@types/node": "24.13.3",
    "vite": "6.4.3"
  }
}
